# ============================================================================
# Application Configuration
# ============================================================================
APP_NAME="Socia Auth"
# Environment: local, staging, production
# Local environment
APP_ENV=local
# Staging environment (uncomment to use staging)
# APP_ENV=staging
# Production environment (uncomment to use production)
# APP_ENV=production

APP_KEY=

# Debug mode
# Local environment
APP_DEBUG=true
# Staging/Production environment (uncomment to use)
# APP_DEBUG=false

# Application URL
# Local environment
APP_URL=http://localhost:8000
# Staging environment (uncomment to use staging)
# APP_URL=https://auth.socia-dev.com
# Production environment (uncomment to use production)
# APP_URL=https://auth.yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Local environment
LOG_LEVEL=debug
# Staging environment (uncomment to use staging)
# LOG_LEVEL=info

# ============================================================================
# Database Configuration
# ============================================================================
DB_CONNECTION=mysql
# Local environment
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=socia_auth
DB_USERNAME=
DB_PASSWORD=
# Staging environment (uncomment and update)
# DB_HOST=staging-db-host
# DB_PORT=3306
# DB_DATABASE=staging_rzauth_db
# DB_USERNAME=staging_user
# DB_PASSWORD=staging_password
# Production environment (uncomment and update)
# DB_HOST=production-db-host
# DB_PORT=3306
# DB_DATABASE=production_rzauth_db
# DB_USERNAME=production_user
# DB_PASSWORD=production_password


# ============================================================================
# Session Configuration (Critical for Integration)
# ============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_ENCRYPT=false
SESSION_PATH=/

# Session Cookie Name - MUST match backend HRIS_AUTH_SESSION_COOKIE
# This is the cookie name that backend services will look for
SESSION_COOKIE=auth-session

# Session Cookie Domain
# Local environment - null allows localhost and 127.0.0.1
SESSION_DOMAIN=null
# Staging environment (uncomment to use staging)
# SESSION_DOMAIN=.socia-dev.com
# Production environment (uncomment to use production)
# SESSION_DOMAIN=.yourdomain.com

# Session Cookie Security
# Local environment
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
# Staging/Production environment (uncomment to use)
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=none

# Session HTTP Only (recommended: true for security)
SESSION_HTTP_ONLY=true

# ============================================================================
# Queue & Cache Configuration
# ============================================================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Cache Store: database, redis, file, array
# Local environment
CACHE_STORE=database
# For better performance, use redis (uncomment if Redis is configured)
# CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# ============================================================================
# Redis Configuration (Optional - for caching and sessions)
# ============================================================================
# Local environment
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
# Staging environment (uncomment and update)
# REDIS_HOST=staging-redis-host
# REDIS_PASSWORD=staging-redis-password
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_CACHE_DB=1
# Production environment (uncomment and update)
# REDIS_HOST=production-redis-host
# REDIS_PASSWORD=production-redis-password
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_CACHE_DB=1

# Mail Configuration
# Local environment
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"
# Production environment - mail is disabled (log only)
# MAIL_MAILER=log
# MAIL_HOST=null
# MAIL_PORT=null
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_FROM_ADDRESS="noreply@yourdomain.com"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================================================
# Frontend Build Configuration
# ============================================================================
VITE_APP_NAME="${APP_NAME}"
FRONTEND_URL=http://localhost:3000

# ============================================================================
# Social Auth (OAuth)
# ============================================================================
# Google — https://console.cloud.google.com -> APIs & Services -> Credentials
# Authorized redirect URI: http://localhost:8000/api/auth/social/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook — https://developers.facebook.com -> Your App -> Facebook Login
# Valid OAuth redirect URI: http://localhost:8000/api/auth/social/facebook/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ============================================================================
# Sanctum Configuration (Stateful API Authentication)
# ============================================================================
# Domains that can receive stateful authentication cookies
# Local environment
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:8000,127.0.0.1,127.0.0.1:3000
# Production environment (uncomment and update)
# SANCTUM_STATEFUL_DOMAINS=yourdomain.com,www.yourdomain.com

# Sanctum Token Prefix (optional, for security scanning)
SANCTUM_TOKEN_PREFIX=

# ============================================================================
# CORS Configuration (Cross-Origin Resource Sharing)
# ============================================================================
# Allowed origins for CORS requests
# Local environment
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production environment (uncomment and update)
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# Generic Auth Service Integration Configuration
# ============================================================================
# These variables are used by backend services to integrate with this Auth service
# Backend services will use these to configure HRIS_AUTH_URL, HRIS_AUTH_SESSION_COOKIE, etc.

# Auth Service Base URL (used by backend services)
# Local environment
AUTH_SERVICE_URL=http://127.0.0.1:8000
# Staging environment (uncomment to use staging)
# AUTH_SERVICE_URL=https://auth.socia-dev.com
# Production environment (uncomment to use production)
# AUTH_SERVICE_URL=https://auth.yourdomain.com

# Session Cookie Name (exported for backend services)
# This should match SESSION_COOKIE above
AUTH_SESSION_COOKIE_NAME=auth-session

# CSRF Cookie Name (exported for backend services)
AUTH_CSRF_COOKIE_NAME=XSRF-TOKEN

# Request Timeout (seconds) for backend service requests
AUTH_REQUEST_TIMEOUT=30
